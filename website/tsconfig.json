{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@convex/_generated/api": ["./convex_generated/api"],
      "@convex/_generated/dataModel": ["./convex_generated/dataModel"],
      "@convex/_generated/server": ["./convex_generated/server"],
      "convex/*": ["./node_modules/convex/*"],
      "@convex-dev/*": ["./node_modules/@convex-dev/*"],
      "@better-auth/*": ["./node_modules/@better-auth/*"],
      "better-auth": ["./node_modules/better-auth"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../convex/_generated/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
