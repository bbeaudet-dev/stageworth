# Convex deployment URL (same as the mobile app)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Android beta: Expo *build* page URL (expo.dev/.../builds/...) so testers can download the .apk.
# Update in Vercel + redeploy when you publish a new EAS Android build.
# NEXT_PUBLIC_ANDROID_APK_URL=https://expo.dev/accounts/your-account/projects/your-app/builds/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Password to access /admin routes (leave unset to skip protection in local dev)
ADMIN_PASSWORD=choose-a-strong-password
