# Convex deployment URL (same as the mobile app)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
# Convex site URL (auth endpoint — same as mobile app's EXPO_PUBLIC_CONVEX_SITE_URL)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
# Your Convex user ID for admin access
NEXT_PUBLIC_ADMIN_USER_ID=your_convex_user_id
