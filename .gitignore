# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
# Root app uses Bun (bun.lock); ignore accidental npm lock at repo root only
/package-lock.json

# Next/Vercel: minimal Convex install + symlink (see website/scripts/vercel-install.js)
.convex-vendor/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# IDE
.idea/

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# Firebase
google-services.json

# typescript
*.tsbuildinfo

app-example

# Convex
# _generated is committed so EAS cloud builds have the Convex API types
# convex/_generated/

# generated native folders
/ios
/android

# local data / import artifacts (entire tree ignored except showtimes/)
data/*
!data/showtimes/
!data/showtimes/**

# Generated by scripts/fetchWeeklyShowtimes.mjs for PR bodies (local/CI artifact)
.github/pr-body.md

# Large one-off Convex export JSON pasted for manual import (do not commit)
docs/migration/

# news bot runtime artifacts
bot/node_modules/
bot/seen.db
bot/.env
