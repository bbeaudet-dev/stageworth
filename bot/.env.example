# Anthropic API key for Claude parsing
ANTHROPIC_API_KEY=sk-ant-...

# Your Convex deployment's HTTP site URL (e.g. https://xxxxx.convex.site)
CONVEX_BOT_URL=https://xxxxx.convex.site/bot/ingest

# Shared secret — must match BOT_SECRET set in Convex env vars
# Set on Convex side with: bunx convex env set BOT_SECRET <value>
BOT_SECRET=changeme

# Usage:
#   bun install
#   cp .env.example .env  # fill in values
#   DRY_RUN=true bun run dev    # test: logs only, no Convex writes
#   bun run start               # production
#
# With pm2 (install once: bun add -g pm2):
#   pm2 start --name theatre-bot --interpreter bun src/index.ts
#   pm2 startup && pm2 save
